# =============================================================================
# Agentic RAG Ecosystem — Environment Variables
# Copy to .env and fill in your values.
# =============================================================================

# ---------------------------------------------------------------------------
# Docker / Infrastructure
# ---------------------------------------------------------------------------
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
# REQUIRED — no default. docker compose refuses to start if this is unset.
# Generate one: openssl rand -base64 24
N8N_BASIC_AUTH_PASSWORD=

SEARXNG_BASE_URL=http://localhost:8080
# REQUIRED — no default. Generate one: openssl rand -hex 32
SEARXNG_SECRET_KEY=

# ---------------------------------------------------------------------------
# API access control + binding
# Services bind to 127.0.0.1 by default and trust loopback callers, so the
# local Command Centre keeps working without a key. A key is required only for
# non-local callers (i.e. if you widen HOST to 0.0.0.0 or sit behind a tunnel).
#   API_KEY        — read/standard endpoints (sent as the X-API-Key header)
#   ADMIN_API_KEY  — destructive/paid endpoints (cost reset, memory/vault
#                    mutation, uploads, harness runs, n8n tool calls)
# Generate each: openssl rand -hex 32
# ---------------------------------------------------------------------------
API_KEY=
ADMIN_API_KEY=
# Host the Python services bind to. Keep 127.0.0.1 unless you intend to expose.
HOST=127.0.0.1
# Comma-separated browser origins allowed by CORS (replaces the old "*").
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# Append-only security audit log + pre-write vault backups.
AUDIT_LOG_PATH=logs/audit.jsonl
VAULT_BACKUP_DIR=logs/vault_backups
# Media services only read/write inside these roots (FFmpeg/Whisper sandbox).
MEDIA_INPUT_ROOT=./media_input

# ---------------------------------------------------------------------------
# n8n MCP (workflows exposed as tools via the MCP Server Trigger node)
# ---------------------------------------------------------------------------
N8N_MCP_URL=http://localhost:5678/mcp-server/http
# Bearer token / API key for the MCP Server Trigger (leave blank if no auth).
N8N_MCP_TOKEN=
# Only set this if your trigger uses "Header Auth" instead of Bearer:
# N8N_MCP_HEADER=X-N8N-Api-Key

# ---------------------------------------------------------------------------
# Tool-turn model selection (agentic / "Actions on" path only)
# ---------------------------------------------------------------------------
# When tools are active, the model dropdown (force_model_key) is always honoured
# as long as the chosen model supports function calling. On Auto, the executor
# picks the "smartest" tool-capable model in the lowest funded tier at/above the
# floor below. Normal (non-tool) chat is unaffected.
#
# Lowest tier a tool turn may use. 1 = budget tier (default; Auto -> Gemini 2.5
# Flash). Set to 2 to force mid-tier (e.g. Claude Sonnet 4.6) for all tool work.
# MIN_TOOL_TIER=1
#
# Hard-pin one model for every tool turn, overriding the Auto policy (the UI
# dropdown still takes precedence over this). Must be a function-calling model.
# TOOL_MODEL_KEY=anthropic/claude-sonnet-4-6

# ---------------------------------------------------------------------------
# Qdrant
# ---------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=obsidian_vault

# ---------------------------------------------------------------------------
# Ollama (local LLM)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
EMBED_URL=http://localhost:11434/api/embeddings
EMBED_MODEL=nomic-embed-text

# ---------------------------------------------------------------------------
# DeepSeek-R1 (cloud LLM)
# ---------------------------------------------------------------------------
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-reasoner

# ---------------------------------------------------------------------------
# Model Router thresholds + classifier
# ---------------------------------------------------------------------------
ROUTER_TOKEN_THRESHOLD=512
# Scored task classifier: below either threshold the router falls back to the
# safe default task type instead of guessing.
ROUTER_MIN_CONFIDENCE=0.45
ROUTER_MIN_MARGIN=0.15
ROUTER_DEFAULT_TASK=advisory
# Optional embedding refinement stage (off by default; needs tuned centroids).
ROUTER_USE_EMBEDDING=0
# ROUTER_CENTROID_PATH=logs/router_centroids.json
# Where routing decisions are logged for offline tuning.
ROUTING_LOG_PATH=logs/routing_decisions.jsonl

# ---------------------------------------------------------------------------
# Obsidian Vault
# ---------------------------------------------------------------------------
OBSIDIAN_VAULT_PATH=C:/Users/ajwij/OneDrive/Documents/Obsidian Vault
WRITING_PIPELINE_PATH=09_Writing Pipline
# Folder inside the vault used for planner project notes. 
OBSIDIAN_PROJECTS_PATH=)5_Projects
CHUNK_SIZE=400
CHUNK_OVERLAP=50

# ---------------------------------------------------------------------------
# WijerCo agent folder
# The RAG system reads department definitions, knowledge base, and ABOUT ME
# files directly from this folder. Must point to the real WijerCo Cowork
# directory. All 6 department agents + knowledge base are auto-indexed on
# first startup via POST /index/wijerco.
# ---------------------------------------------------------------------------
WIJERCO_PATH=C:/Users/ajwij/Claude Cowork/WijerCo
WIJERCO_WORKFORCE_PATH=C:/Users/ajwij/OneDrive/Documents/Agents/agentic-rag-ecosystem/workforce
WIJERCO_COLLECTION=wijerco_knowledge

# ---------------------------------------------------------------------------
# Agent service ports
# ---------------------------------------------------------------------------
LOCAL_DATA_AGENT_PORT=8001
SEARCH_AGENT_PORT=8002
CLOUD_AGENT_PORT=8003
NOTIFIER_PORT=8004
INDEXER_PORT=8005
RETRIEVER_PORT=8006
WHISPER_PORT=8007
VIDEO_PIPELINE_PORT=8008

# Agent URLs (used by the orchestrator rag_node)
LOCAL_DATA_AGENT_URL=http://localhost:8001
SEARCH_AGENT_URL=http://localhost:8002
CLOUD_AGENT_URL=http://localhost:8003
NOTIFIER_URL=http://localhost:8004
INDEXER_URL=http://localhost:8005

# ---------------------------------------------------------------------------
# Search
# ---------------------------------------------------------------------------
SEARXNG_URL=http://localhost:8080
TAVILY_API_KEY=                         # Optional fallback

# ---------------------------------------------------------------------------
# Media
# ---------------------------------------------------------------------------
WHISPER_MODEL=base                      # tiny | base | small | medium | large-v2
WHISPER_DEVICE=cpu                      # cpu | cuda | mps
WHISPER_COMPUTE=int8                    # int8 | float16 | float32
TRANSCRIPT_OUTPUT_DIR=./transcripts
VIDEO_OUTPUT_DIR=./video_output

# Media adapters. Local/self-hosted paths are the default. Set a capability to
# mcp:<provider> to route through a connected MCP bridge; MCP calls require the
# paid_job governance approval for the production/job target before they run.
ADAPTER_IMAGE=self
ADAPTER_VIDEO=self
ADAPTER_AUDIO=self
ADAPTER_TRANSCRIBE=self
ADAPTER_VISUAL_EMBED=self
ADAPTER_DOCUMENT=self
ADAPTER_PRESENTATION=self

# Local multimedia tool registry. Defaults are inserted into data/media.db on
# first use. Override only when a tool lives outside PATH or a local worker is
# exposed over HTTP.
# MEDIA_TOOL_FFMPEG_COMMAND=ffmpeg
# MEDIA_TOOL_REMOTION_COMMAND=npx
# MEDIA_TOOL_COMFYUI_ENDPOINT=http://127.0.0.1:8188
# MEDIA_TOOL_PIPER_COMMAND=piper
# MEDIA_TOOL_XTTS_ENDPOINT=http://127.0.0.1:8020
# MEDIA_TOOL_MUSETALK_ENDPOINT=http://127.0.0.1:7860
# MEDIA_TOOL_SADTALKER_ENDPOINT=http://127.0.0.1:7861
# MEDIA_TOOL_MANIM_COMMAND=manim
# MEDIA_TOOL_BLENDER_COMMAND=blender
# MEDIA_TOOL_DEFAULT_VIDEO=ffmpeg
# MEDIA_TOOL_DEFAULT_IMAGE=comfyui
# MEDIA_TOOL_DEFAULT_AUDIO=piper
# Set MEDIA_TOOL_<NAME>_ENABLED=0 to disable a local tool, for example:
# MEDIA_TOOL_REMOTION_ENABLED=0

# Canva MCP bridge for document/deck production from Content Studio outputs.
# Example: ADAPTER_DOCUMENT=mcp:canva or ADAPTER_PRESENTATION=mcp:canva
MCP_MEDIA_URL=
MCP_MEDIA_TOKEN=
# MCP_MEDIA_HEADER=X-Api-Key
# CANVA_DOCUMENT_CREATE_TOOL=canva_create_document
# CANVA_DOCUMENT_COPY_TOOL=canva_copy_document
# CANVA_PRESENTATION_CREATE_TOOL=canva_create_presentation
# CANVA_PRESENTATION_COPY_TOOL=canva_copy_presentation

# ---------------------------------------------------------------------------
# Notifications (Apprise)
# ---------------------------------------------------------------------------
APPRISE_TELEGRAM_TOKEN=
APPRISE_TELEGRAM_CHAT_ID=
APPRISE_EMAIL_HOST=smtp.gmail.com
APPRISE_EMAIL_PORT=587
APPRISE_EMAIL_USER=
APPRISE_EMAIL_PASS=
APPRISE_EMAIL_TO=
APPRISE_DESKTOP=false
# Comma-separated extra Apprise URLs.
APPRISE_EXTRA_URLS=

# ---------------------------------------------------------------------------
# Multi-LLM API Keys
# Add the keys you have — the optimizer only uses models with configured keys.
# Ollama (local) is always available at no cost.
# ---------------------------------------------------------------------------

# Anthropic — Claude Haiku (Tier 1), Sonnet (Tier 2), Opus / Fable (Tier 3)
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI — GPT-4o-mini (Tier 1), GPT-4o (Tier 2), GPT-4 Turbo / o1 (Tier 3)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Google — Gemini Flash (Tier 1), Gemini Pro (Tier 2)
# Get key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# DeepSeek — DeepSeek Chat (Tier 1), DeepSeek-R1 (Tier 2)
# Get key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# WijerCo agent settings
CLAUDE_MODEL=claude-sonnet-4-6    # Default model for WijerCo agents (overridden by optimizer)
WIJERCO_MAX_TOKENS=4096

# Session storage for conversation persistence (SQLite)
SESSION_DB_PATH=data/sessions.db
SESSION_TTL_HOURS=24

# Qdrant collection for long-term agent memory
MEMORY_COLLECTION=agent_memory

# ---------------------------------------------------------------------------
# Cloud storage (optional)
# ---------------------------------------------------------------------------
# GCS: use Application Default Credentials from `gcloud auth application-default login`
# or point GOOGLE_APPLICATION_CREDENTIALS at a downloaded service-account JSON file.
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
GCS_BUCKET=
# AWS:
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Hybrid retrieval
# ---------------------------------------------------------------------------
# Cross-encoder rerank on the default local path. Set 0 on memory-constrained
# machines to skip loading sentence-transformers.
RETRIEVER_USE_RERANKER=1

# ---------------------------------------------------------------------------
# Context assembly (dedupe / diversity / recency / compression)
# ---------------------------------------------------------------------------
CONTEXT_MAX_CHUNKS=8
CONTEXT_TOKEN_BUDGET=2000
CONTEXT_DEDUPE_THRESHOLD=0.85
CONTEXT_MAX_PER_FILE=3
# CONTEXT_MAX_PER_COLLECTION=0          # 0 = no cap
CONTEXT_RECENCY_WEIGHT=0.15
CONTEXT_RECENCY_HALFLIFE_DAYS=180

# ---------------------------------------------------------------------------
# Observability (per-request traces)
# ---------------------------------------------------------------------------
TRACE_LOG_PATH=logs/traces.jsonl
TRACE_LOG_MAX_BYTES=10485760

# ---------------------------------------------------------------------------
# Operational reliability
# ---------------------------------------------------------------------------
# Exit non-zero at startup if a hard dependency (e.g. Qdrant) is down.
STRICT_STARTUP=0
# Shared retry/backoff policy for httpx calls to Qdrant/Ollama/agents.
RETRY_ATTEMPTS=3
RETRY_MIN_WAIT=0.5
RETRY_MAX_WAIT=8.0
# Provider failure cooldown (persisted so it survives a restart).
PROVIDER_FAILURE_COOLDOWN=120
PROVIDER_COOLDOWN_PATH=logs/provider_cooldowns.json

# ---------------------------------------------------------------------------
# Independence layer: operating daemon, budget breaker, channels
# ---------------------------------------------------------------------------
# Budget circuit breaker. 0 disables. Warn at BUDGET_WARN_RATIO, stop at 100%.
MONTHLY_BUDGET_USD=50
BUDGET_WARN_RATIO=0.8

# Operating daemon (python -m orchestrator.daemon)
DAEMON_INTERVAL_SEC=60
DAEMON_DRY_RUN=1
DAEMON_MAX_ATTEMPTS=2
DAEMON_AGENT_MAX_TIER=2

# Telegram channel (python -m channels.telegram_bot)
# Both fall back to APPRISE_TELEGRAM_TOKEN / APPRISE_TELEGRAM_CHAT_ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=

# Email channel (python -m channels.email_poller)
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_USER=
EMAIL_PASS=
EMAIL_ALLOWED_SENDERS=
EMAIL_POLL_SEC=300

# Orchestrator location for the channel processes (loopback needs no key)
ORCHESTRATOR_URL=http://localhost:8000
ORCH_API_KEY=

# RBAC role keys (JSON: {"viewer":"...","operator":"...","admin":"..."}).
# Falls back to API_KEY (operator) and ADMIN_API_KEY (admin) when empty.
RBAC_ROLE_KEYS=

# One-click approval links in notification emails. Links render only when
# PUBLIC_BASE_URL is set (e.g. your Tailscale serve URL). Secret falls back
# to ADMIN_API_KEY then API_KEY.
PUBLIC_BASE_URL=
APPROVAL_LINK_SECRET=
APPROVAL_LINK_TTL_HOURS=24

# Nightly memory consolidation (run by the daemon)
CONSOLIDATION_HOUR=2
EPISODIC_RETENTION_DAYS=90
CONSOLIDATION_PROMOTE_MIN=3

# ---------------------------------------------------------------------------
# Cloud media providers: voice clone + avatar clone
# See docs/clone-and-video-runbook.md. All clone output stops at the
# clone_output governance gate before leaving the system.
# ---------------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
# HEYGEN_VOICE_ID=            # only for text mode; audio mode uses ElevenLabs output
MEDIA_TOOL_DEFAULT_VOICE=elevenlabs
MEDIA_TOOL_DEFAULT_AVATAR=heygen

# GPU PC as optional self-hosted worker over Tailscale (see runbook)
# MEDIA_TOOL_COMFYUI_ENDPOINT=http://<pc-tailscale-ip>:8188
# MEDIA_TOOL_XTTS_ENDPOINT=http://<pc-tailscale-ip>:8020
# MEDIA_TOOL_SADTALKER_ENDPOINT=http://<pc-tailscale-ip>:7861

# Free clone engines on the GPU PC (see docs/clone-and-video-runbook.md).
# These take precedence over the cloud providers when set.
F5_TTS_URL=
# MEDIA_TOOL_MUSETALK_ENDPOINT and MEDIA_TOOL_SADTALKER_ENDPOINT are listed
# above under GPU workers; point them at the PC's Tailscale IP.
# With the free path, switch the defaults:
# MEDIA_TOOL_DEFAULT_VOICE=f5-tts
# MEDIA_TOOL_DEFAULT_AVATAR=sadtalker

# Publication layer: gated channel delivery
PUBLICATION_DB_PATH=data/media.db
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PRIVACY_STATUS=private
